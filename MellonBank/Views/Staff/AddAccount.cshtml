@model AddAccountViewModel
@{
    ViewData["Title"] = "Άνοιγμα Λογαριασμού";
}

<div class="card shadow border-0 mt-4">
    <div class="card-header bg-success text-white">
        <h4 class="mb-0">Νέος Λογαριασμός για: @Model.CustomerName</h4>
    </div>
    <div class="card-body p-4">
        <form asp-action="AddAccount" method="post">
            <input type="hidden" asp-for="UserId" />
            
            <div class="mb-3">
                <label class="form-label fw-bold">IBAN (Αυτόματη Παραγωγή)</label>
                <input asp-for="IBAN" class="form-control bg-light" readonly />
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label">Υποκατάστημα</label>
                    <input asp-for="BranchName" class="form-control" placeholder="π.χ. Κεντρικό Αθηνών" required />
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label">Τύπος Λογαριασμού</label>
                    <select asp-for="AccountType" class="form-select">
                        <option value="Savings">Ταμιευτηρίου</option>
                        <option value="Current">Τρεχούμενος</option>
                        <option value="Business">Επαγγελματικός</option>
                    </select>
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label">Αρχική Κατάθεση (€)</label>
                <input asp-for="InitialBalance" type="number" step="0.01" class="form-control" value="0.00" />
            </div>

            <div class="mt-4">
                <button type="submit" class="btn btn-success px-5">Επιβεβαίωση Ανοίγματος</button>
                <a asp-action="CustomerList" class="btn btn-secondary">Επιστροφή στη Λίστα</a>
            </div>
        </form>
    </div>
</div>