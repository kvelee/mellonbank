@using Microsoft.CodeAnalysis.CSharp.Syntax
@model IEnumerable<ApplicationUser>
@{
    ViewData["Title"] = "Λίστα Πελατών";
}

<div class="d-flex justify-content-between align-items-center mt-4 mb-3" style="max-width: 1200px">
    <h2>Εγγεγραμμένοι Πελάτες</h2>
    <a asp-action="AddCustomer" class="btn btn-primary">Προσθήκη Πελάτη</a>
</div>

<div class="card shadow-sm border-0" style="max-width: 1200px;">
    <div class="card-body">
        <form asp-action="CustomerList" method="get" class="mb-4">
            <div class="input-group">
                <input type="text" name="searchAfm" class="form-control" placeholder="Αναζήτηση με ΑΦΜ...">
            </div>
        </form>

        <table class="table">
            <thead>
                <tr>
                    <th>ΑΦΜ</th>
                    <th>Όνομα</th>
                    <th>Τηλέφωνο</th>
                    <th class="text-center">Ενέργειες</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var customer in Model) {
                    <tr>
                        <td>@customer.AFM</td>
                        <td>@customer.Name @customer.LastName</td>
                        @if (@customer.PhoneNumber == null) {
                            <td>-</td>

                        }else {
                            <td>@customer.PhoneNumber</td>
                        }
                        
                        <td class="text-center d-flex justify-content-evenly">
                            <a asp-action="DetailsCustomer" asp-route-id="@customer.Id" class="btn btn-sm"> <u> Λεπτομέρειες </u></a>
                            <a asp-action="EditCustomer" asp-route-afm="@customer.AFM" class="btn btn-sm btn-warning">Επεξεργασία</a>
                            <form asp-action="DeleteCustomer" asp-route-afm="@customer.AFM" method="post" style="display:inline">
                                <button type="button" class="btn btn-sm btn-outline-danger" onclick="confirmDelete('@customer.AFM')">
                                    <i class="bi bi-trash"></i> Διαγραφή
                                </button>
                            </form>
                            <a asp-action="AddAccount" asp-route-userId="@customer.Id" class="btn btn-sm btn-success">Προσθήκη Λογαριασμού</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title">Επιβεβαίωση Διαγραφής</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                Είστε βέβαιοι ότι θέλετε να διαγράψετε τον πελάτη με ΑΦΜ: <strong id="displayAfm"></strong>;
                <p class="text-danger small mt-2">Προσοχή: Θα διαγραφούν και όλοι οι συνδεδεμένοι λογαριασμοί.</p>
            </div>
            <div class="modal-footer">
                <form asp-action="DeleteCustomer" method="post">
                    <input type="hidden" name="afm" id="inputAfm" />
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Ακύρωση</button>
                    <button type="submit" class="btn btn-danger">Διαγραφή</button>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
    function confirmDelete(afm) {
        document.getElementById('displayAfm').innerText = afm;
        document.getElementById('inputAfm').value = afm;
        new bootstrap.Modal(document.getElementById('deleteModal')).show();
    }
</script>
