@using Microsoft.CodeAnalysis.CSharp.Syntax
@using System.Globalization
@model IEnumerable<BankAccount>
@{
    ViewData["Title"] = "Ο Λογαριασμός μου";
}

<div class="container mt-4">
    <div class="row mb-4">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h2 class="fw-bold text-dark">Καλώς ορίσατε, @ViewBag.CustomerName</h2>
                <p class="text-muted mb-0">Διαχείριση των οικονομικών σας</p>
            </div>
            <div class="d-flex gap-2">
                <a asp-action="ChangePassword" class="btn btn-outline-secondary rounded-pill px-3">
                    <i class="bi bi-gear-fill"></i> Ασφάλεια
                </a>
                <a asp-action="Transfer" class="btn btn-success shadow-sm rounded-pill px-4">
                    <i class="bi bi-arrow-left-right me-2"> Μεταφορά Χρημάτων</i>
                </a>
            </div>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info border-0 shadow-sm">
            <i class="bi bi-info-circle-fill me-2"></i>
            Δεν βρέθηκαν ενεργοί τραπεζικοί λογαριασμοί. Παρακαλούμε επικοινωνήστε με ένα κατάστημα.
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var account in Model)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 border-0 shadow-sm rounded-4 overflow-hidden">

                        @if (account.AccountType == "Savings")
                        {
                            <div class="card-header bg-primary text-white py-3 border-0">
                                <small class="text-uppercase opacity-75">@account.AccountType</small>
                                <h5 class="mb-0 fw-bold">@account.BranchName</h5>
                            </div>
                        }
                        else if (account.AccountType == "Current")
                        {
                            <div class="card-header text-white py-3 border-0" style="background-color: rgb(255, 181, 45);">
                                <small class="text-uppercase opacity-75">@account.AccountType</small>
                                <h5 class="mb-0 fw-bold">@account.BranchName</h5>
                            </div>
                        }
                        else if (account.AccountType == "Business")
                        {
                            <div class="card-header text-white py-3 border-0" style="background: linear-gradient(135deg, #c0c0c0, #808080);">
                                <small class="text-uppercase opacity-75">@account.AccountType</small>
                                <h5 class="mb-0 fw-bold">@account.BranchName</h5>
                            </div>
                        }

                        <div class="card-body p-4">
                            <p class="text-muted small mb-1">IBAN</p>
                            <p class="font-monospace fw-bold text-primary mb-4">@account.IBAN</p>

                            <hr class="my-3 opacity-10">

                            <div class="d-flex justify-content-between align-items-end">
                                <div>
                                    <p class="text-muted small mb-0">
                                        Διαθέσιμο Υπόλοιπο
                                        <small class="text-muted rate-info d-none">: <u>1 EUR = @ViewBag.UsdRate USD</u></small>
                                    </p>
                                    <!-- Rate -->
                                    

                                    <!-- EUR -->
                                    <h3 class="mb-0 fw-bold balance-eur">
                                        @account.Balance.ToString("C2", new CultureInfo("el-GR"))
                                    </h3>

                                    <!-- USD -->
                                    <h3 class="mb-0 fw-bold balance-usd d-none">
                                        @((account.Balance * ViewBag.UsdRate).ToString("C2", new CultureInfo("en-US")))
                                    </h3>

                                    
                                </div>

                                <i class="bi bi-wallet2 fs-1 text-light opacity-50"></i>
                            </div>
                        </div>

                        <div class="card-footer bg-white border-0 p-3">
                            <div class="d-flex gap-2">
                                <a asp-action="History" asp-route-iban="@account.IBAN"
                                   class="btn btn-outline-primary btn-sm w-100 rounded-pill">
                                    Προβολή Κινήσεων
                                </a>

                                <button class="btn btn-outline-secondary btn-sm rounded-pill toggle-currency">
                                    €
                                </button>
                            </div>
                        </div>

                    </div>
                </div>
            }
        </div>
    }
</div>

<style>
    .card { transition: transform 0.2s; }
    .card:hover { transform: translateY(-5px); }
    .bg-primary { background-color: #004a99 !important; }
    .text-primary { color: #004a99 !important; }
</style>

<script>
    document.querySelectorAll('.toggle-currency').forEach(btn => {
        btn.addEventListener('click', function () {

            const card = this.closest('.card');

            const eur = card.querySelector('.balance-eur');
            const usd = card.querySelector('.balance-usd');
            const rate = card.querySelector('.rate-info');

            if (usd.classList.contains('d-none')) {
                eur.classList.add('d-none');
                usd.classList.remove('d-none');
                rate.classList.remove('d-none');
                this.textContent = '$';
            } else {
                eur.classList.remove('d-none');
                usd.classList.add('d-none');
                rate.classList.add('d-none');
                this.textContent = '€';
            }
        });
    });
</script>