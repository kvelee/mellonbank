@model ChangePasswordViewModel
@{
    ViewData["Title"] = "Αλλαγή Κωδικού";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow border-0">
                <div class="card-header bg-dark text-white text-center py-3" style="border-radius: 8px; margin-top: 4px">
                    <h5 class="mb-0">Αλλαγή Κωδικού Πρόσβασης</h5>
                </div>
                <div class="card-body p-4">
                    <form asp-action="ChangePassword" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                        <div class="mb-3">
                            <label class="form-label">Παλαιός Κωδικός</label>
                            <input asp-for="OldPassword" class="form-control" />
                            <span asp-validation-for="OldPassword" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Νέος Κωδικός</label>
                            <input asp-for="NewPassword" class="form-control" />
                            <span asp-validation-for="NewPassword" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label class="form-label">Επιβεβαίωση Νέου Κωδικού</label>
                            <input asp-for="ConfirmPassword" class="form-control" />
                            <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                        </div>

                        <button type="submit" class="btn btn-primary w-100">Ενημέρωση Κωδικού</button>
                        <a asp-action="Index" class="btn btn-link w-100 mt-2 text-decoration-none">Ακύρωση</a>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>