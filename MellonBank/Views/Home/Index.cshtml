@model LoginViewModel
@{
    ViewData["Title"] = "MellonBank - Είσοδος";
    Layout = "_Layout";
}

<div class="container mt-5">
    <div class="row align-items-center">
        <div class="col-lg-6 text-center text-lg-start">
            <h1 class="display-3 fw-bold mb-3 text-primary">MellonBank</h1>
            <p class="lead">Η σύγχρονη πλατφόρμα e-banking για την ασφαλή διαχείριση των οικονομικών σας</p>
        </div>

        <div class="col-lg-5 offset-lg-1">
            <div class="card shadow-lg border-0">
                <div class="card-body p-5">
                    <h3 class="mb-4 text-center">Είσοδος στην MellonBank</h3>
                    <form asp-action="Index" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>
                        
                        <div class="form-floating mb-3">
                            <input asp-for="Email" class="form-control" />
                            <label>Email ή Username</label>
                        </div>
                        
                        <div class="form-floating mb-4">
                            <input asp-for="Password" type="password" class="form-control" />
                            <label>Κωδικός Πρόσβασης</label>
                        </div>

                        <button type="submit" class="btn btn-primary btn-lg w-100">Σύνδεση</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>